# ── Anthropic (Required) ──────────────────────────────────────────────────────
# Your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# ── LangSmith tracing (Required for tracing) ─────────────────────────────────
# Get your key at https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=Agent-Team-Meeting

# ── Optional model settings ───────────────────────────────────────────────────
# Claude model to use — claude-haiku-4-5-20251001 is fast; claude-sonnet-4-6 is stronger
# MODEL_NAME=claude-haiku-4-5-20251001

# Sampling temperature: 0 = deterministic (recommended for tool-use agents)
# TEMPERATURE=0
