# ── Google Gemini (Required) ──────────────────────────────────────────────────
# Free API key → https://aistudio.google.com → Get API key
GOOGLE_API_KEY=AIza...

# ── LangSmith tracing ────────────────────────────────────────────────────────
# Free key → https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=Agent-Team-Meeting

# ── Optional model settings ───────────────────────────────────────────────────
# gemini-2.5-flash = fast & free  |  gemini-2.5-pro = stronger reasoning
# MODEL_NAME=gemini-2.5-flash

# TEMPERATURE=0
